# Copy these into your shell or job launcher and edit per machine.

# Alpamayo 1.5 source. Optional if alpamayo1_5 is already importable.
export ALPAMAYO15_SRC=/path/to/alpamayo1.5/src

# Model loading.
export ALPAMAYO15_MODEL_ID=nvidia/Alpamayo-1.5-10B
export ALPAMAYO15_MODEL_CACHE_DIR=/path/to/huggingface/cache
# export ALPAMAYO15_MODEL_REVISION=main
# export ALPAMAYO15_LOCAL_FILES_ONLY=1

# Transformers attention implementation. Alpamayo 1.5 commonly needs eager.
export ALPAMAYO15_ATTN_IMPLEMENTATION=eager

# Default profiling/inference input.
export ALPAMAYO15_CLIP_ID=030c760c-ae38-49aa-9ad8-f5650a545d26
export ALPAMAYO15_T0_US=5100000
export ALPAMAYO15_DATASET_REVISIONS=2ae73f49ffd2b5db43b404201beb7b92889f7afc,37a7cc2c868d684d0456b5412a7ec5d18597a96a
